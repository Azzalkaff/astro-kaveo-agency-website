<section class="cta">
  <div class="cta-container">
    <div class="cta-content animate-fade-up">
      <h2 class="cta-title">Ready to Dominate Your Local Area?</h2>
      <p class="cta-desc">
        Let's discuss how we can flood your business with new local leads in Brisbane, Perth, or Adelaide. No pressure, no obligations. Just a friendly chat about your goals.
      </p>
      <div class="cta-actions">
        <a href="https://wa.me/61412345678" class="btn btn-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          Chat on WhatsApp
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .cta {
    padding: 8rem 0;
    position: relative;
    overflow: hidden;
    background-image: url('https://images.unsplash.com/photo-1504307651254-35680f356dfd?auto=format&fit=crop&q=80&w=2000'); /* Premium construction/tradie image */
    background-size: cover;
    background-position: center;
    background-attachment: fixed; /* Creates a premium parallax effect */
  }

  .cta::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(15, 23, 42, 0.75); /* Dark blue overlay */
    z-index: 1;
  }

  .cta-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 2rem;
    position: relative;
    z-index: 2;
  }

  .cta-content {
    text-align: center;
    background-color: var(--color-cream);
    padding: 4rem 3rem;
    border-radius: 20px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
  }

  .cta-title {
    font-size: clamp(2rem, 4vw, 2.8rem);
    color: var(--color-primary);
    margin-bottom: 1.5rem;
  }

  .cta-desc {
    font-size: 1.15rem;
    color: var(--color-text-muted);
    margin-bottom: 2.5rem;
    line-height: 1.7;
  }

  .cta-actions {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
  }

  .btn {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2.5rem;
    border-radius: 50px;
    font-weight: 600;
    font-size: 1.1rem;
    transition: all 0.3s ease;
    cursor: pointer;
    text-decoration: none;
  }

  .btn-primary {
    background-color: var(--color-primary);
    color: var(--color-cream);
    border: 2px solid var(--color-primary);
  }

  .btn-primary:hover {
    background-color: var(--color-accent);
    border-color: var(--color-accent);
    transform: translateY(-3px);
    box-shadow: 0 10px 20px rgba(59, 130, 246, 0.2);
  }

  @media (max-width: 640px) {
    .cta-content {
      padding: 3rem 1.5rem;
    }
    .cta-actions {
      flex-direction: column;
    }
    .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
