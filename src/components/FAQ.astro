<section id="faq" class="faq-section">
  <div class="faq-container">
    <!-- Kolom Kiri: Judul -->
    <div class="faq-header animate-fade-up">
      <p class="subtitle">100% Transparency</p>
      <h2 class="section-title">Got Questions?</h2>
      <p class="section-desc">Here is everything you need to know about how I operate, what you pay for, and what to expect.</p>
      <a href="https://wa.me/61412345678" class="btn-text">Still have questions? Chat on WhatsApp &rarr;</a>
    </div>

    <!-- Kolom Kanan: Accordion Cards -->
    <div class="faq-accordion animate-fade-up delay-100">
      
      <!-- FAQ Card 1 -->
      <div class="faq-card">
        <button class="faq-trigger" aria-expanded="false">
          <span class="faq-question">Are Domain & Hosting included?</span>
          <div class="icon-box">
            <span class="plus-icon"></span>
          </div>
        </button>
        <div class="faq-content">
          <div class="faq-inner">
            <p><strong>No.</strong> To register a <code>.com.au</code> domain, you must have an active Australian Business Number (ABN). Therefore, you need to <strong>purchase the domain yourself</strong> (usually ~$20/year).</p>
            <p>However, because I build blazing-fast static websites, I can set up your hosting for <strong>100% FREE</strong> on premium servers like Netlify or Vercel. I will guide you step-by-step through the entire process.</p>
          </div>
        </div>
      </div>

      <!-- FAQ Card 2 -->
      <div class="faq-card">
        <button class="faq-trigger" aria-expanded="false">
          <span class="faq-question">How long does it take to build?</span>
          <div class="icon-box">
            <span class="plus-icon"></span>
          </div>
        </button>
        <div class="faq-content">
          <div class="faq-inner">
            <p>Typically, building your custom website takes <strong>7 to 14 days</strong>, depending on how quickly you provide photos and business details.</p>
            <p>Google Maps optimization is usually completed within <strong>3-5 days</strong>.</p>
          </div>
        </div>
      </div>

      <!-- FAQ Card 3 -->
      <div class="faq-card">
        <button class="faq-trigger" aria-expanded="false">
          <span class="faq-question">Are there any hidden monthly fees?</span>
          <div class="icon-box">
            <span class="plus-icon"></span>
          </div>
        </button>
        <div class="faq-content">
          <div class="faq-inner">
            <p><strong>Absolutely not.</strong> If you buy the 'Website Only' package, you pay the <strong>one-time fee of $699</strong>, and that's it. <strong>You own the website 100%</strong>.</p>
            <p>If you opt for ongoing SEO or GBP Management, it's a month-to-month agreement with <strong>zero lock-in contracts</strong>. You can cancel anytime.</p>
          </div>
        </div>
      </div>

      <!-- FAQ Card 4 -->
      <div class="faq-card">
        <button class="faq-trigger" aria-expanded="false">
          <span class="faq-question">Why is your pricing so affordable?</span>
          <div class="icon-box">
            <span class="plus-icon"></span>
          </div>
        </button>
        <div class="faq-content">
          <div class="faq-inner">
            <p>Because I am a solo-operator based in Indonesia. You are <strong>not paying for an expensive Sydney office</strong>, account managers, or corporate overhead. You are paying purely for the technical execution and the final result: <strong>a high-converting digital asset</strong> that gets you more leads.</p>
          </div>
        </div>
      </div>

      <!-- FAQ 5 -->
      <div class="faq-card">
        <button class="faq-trigger" aria-expanded="false">
          <span class="faq-question">What if I need to change text or photos later?</span>
          <div class="icon-box">
            <span class="plus-icon"></span>
          </div>
        </button>
        <div class="faq-content">
          <div class="faq-inner">
            <p>During the build process, you get <strong>2 rounds of revisions</strong> to make sure everything is perfect before we launch.</p>
            <p>After launch, because I custom-code your site for maximum speed and security (no clunky WordPress dashboards), I handle all updates for you. For minor text or photo changes, you can simply text me on WhatsApp and I'll update it for a small flat fee, or you can opt for a cheap monthly maintenance plan.</p>
          </div>
        </div>
      </div>

      <!-- FAQ 6 -->
      <div class="faq-card">
        <button class="faq-trigger" aria-expanded="false">
          <span class="faq-question">How do we communicate across timezones?</span>
          <div class="icon-box">
            <span class="plus-icon"></span>
          </div>
        </button>
        <div class="faq-content">
          <div class="faq-inner">
            <p>Indonesia is only 1 to 3 hours behind Australia (depending on your state and daylight savings). This means we work during the exact same business hours. Communication via WhatsApp is instant, seamless, and you will never wait 24 hours for a reply.</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .faq-section {
    padding: 8rem 0;
    background-color: var(--color-cream);
    color: var(--color-primary);
  }

  .faq-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 4rem;
    align-items: flex-start;
  }

  /* Kiri: Header */
  .subtitle {
    font-size: 1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .section-title {
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    color: var(--color-primary);
    margin-bottom: 1.5rem;
    line-height: 1.1;
  }

  .section-desc {
    font-size: 1.15rem;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .btn-text {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .btn-text:hover {
    color: var(--color-cream);
  }

  /* Kanan: Accordion Cards */
  .faq-accordion {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .faq-card {
    background-color: #ffffff;
    border: 1px solid rgba(15, 23, 42, 0.05);
    border-radius: 0;
    overflow: hidden;
    transition: all 0.3s ease;
    box-shadow: 0 4px 10px rgba(15, 23, 42, 0.02);
  }

  .faq-card:hover {
    border-color: rgba(15, 23, 42, 0.1);
    box-shadow: 0 10px 20px rgba(15, 23, 42, 0.05);
  }

  .faq-card.active {
    background-color: #ffffff;
    border-color: var(--color-accent);
  }

  .faq-trigger {
    width: 100%;
    text-align: left;
    background: none;
    border: none;
    padding: 1.5rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    font-family: inherit;
  }

  .faq-question {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--color-primary);
    padding-right: 2rem;
    transition: color 0.3s ease;
  }

  .faq-card.active .faq-question {
    color: var(--color-accent);
  }

  .icon-box {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: rgba(15, 23, 42, 0.05);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: all 0.3s ease;
  }

  .faq-card.active .icon-box {
    background-color: var(--color-accent);
    transform: rotate(45deg);
  }

  .plus-icon {
    position: relative;
    width: 14px;
    height: 14px;
  }

  .plus-icon::before,
  .plus-icon::after {
    content: '';
    position: absolute;
    background-color: var(--color-primary);
    transition: background-color 0.3s ease;
  }

  .plus-icon::before {
    top: 50%;
    left: 0;
    width: 100%;
    height: 2px;
    transform: translateY(-50%);
  }

  .plus-icon::after {
    top: 0;
    left: 50%;
    width: 2px;
    height: 100%;
    transform: translateX(-50%);
  }

  .faq-card.active .plus-icon::before,
  .faq-card.active .plus-icon::after {
    background-color: #ffffff;
  }

  /* Smooth Height Transition */
  .faq-content {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .faq-card.active .faq-content {
    grid-template-rows: 1fr;
  }

  .faq-inner {
    overflow: hidden;
    padding: 0 2rem;
  }

  .faq-card.active .faq-inner {
    padding: 0 2rem 2rem 2rem;
  }

  .faq-inner p {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .faq-inner p:last-child {
    margin-bottom: 0;
  }

  .faq-inner p strong {
    color: var(--color-primary);
  }

  @media (max-width: 992px) {
    .faq-container {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    
    .faq-header {
      text-align: center;
    }
  }

  @media (max-width: 640px) {
    .faq-trigger {
      padding: 1.25rem 1.5rem;
    }
    
    .faq-inner {
      padding: 0 1.5rem;
    }
    
    .faq-card.active .faq-inner {
      padding: 0 1.5rem 1.5rem 1.5rem;
    }
  }
</style>

<script>
  // Script untuk menangani Accordion Logic
  function initFAQ() {
    const cards = document.querySelectorAll('.faq-card');

    cards.forEach(card => {
      const trigger = card.querySelector('.faq-trigger');
      
      trigger?.addEventListener('click', () => {
        const isActive = card.classList.contains('active');
        
        // Tutup semua kartu yang terbuka (opsional, jika ingin hanya 1 yg terbuka)
        cards.forEach(c => {
          c.classList.remove('active');
          c.querySelector('.faq-trigger')?.setAttribute('aria-expanded', 'false');
        });

        // Buka kartu yang diklik (jika sebelumnya tertutup)
        if (!isActive) {
          card.classList.add('active');
          trigger.setAttribute('aria-expanded', 'true');
        }
      });
    });
  }

  // Menjalankan script saat Astro me-load halaman
  document.addEventListener('DOMContentLoaded', initFAQ);
  
  // Dukungan untuk Astro View Transitions (jika digunakan)
  document.addEventListener('astro:page-load', initFAQ);
</script>
