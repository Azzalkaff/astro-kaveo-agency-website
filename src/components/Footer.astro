---
---

<footer class="footer">
  <div class="footer-container">
    <div class="footer-top">
      <div class="brand">
        <img src="/kaveo-logo.png" alt="Kaveo Logo" style="height: 48px; width: auto; margin-bottom: 0.5rem; transform: scale(2.0); transform-origin: left center;" />
        <p style="margin-top: 1rem;">Local Digital Marketing for Tradies</p>
      </div>
      <div class="contact">
        <a href="mailto:hello@kaveo.com" class="email-link">hello@kaveo.com</a>
        <div class="social-links">
          <a href="#">LinkedIn</a>
          <a href="#">Twitter</a>
          <a href="#">Instagram</a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; {new Date().getFullYear()} Kaveo. All rights reserved.</p>
      <p>Based in Indonesia. Partnering across Australia.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-primary);
    color: var(--color-cream);
    padding: 6rem 0 2rem;
    border-top: 1px solid rgba(249, 246, 240, 0.1);
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .footer-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 4rem;
    flex-wrap: wrap;
    gap: 2rem;
  }

  .brand h2 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
    color: var(--color-cream);
  }

  .brand p {
    color: rgba(249, 246, 240, 0.7);
    font-size: 1.1rem;
  }

  .contact {
    text-align: right;
  }

  .email-link {
    display: inline-block;
    font-size: 1.5rem;
    font-family: var(--font-serif);
    color: var(--color-cream);
    margin-bottom: 1.5rem;
    transition: color 0.3s ease;
  }

  .email-link:hover {
    color: var(--color-accent);
  }

  .social-links {
    display: flex;
    gap: 1.5rem;
    justify-content: flex-end;
  }

  .social-links a {
    color: rgba(249, 246, 240, 0.7);
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: color 0.3s ease;
  }

  .social-links a:hover {
    color: var(--color-cream);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 2rem;
    border-top: 1px solid rgba(249, 246, 240, 0.1);
    font-size: 0.9rem;
    color: rgba(249, 246, 240, 0.5);
  }

  @media (max-width: 768px) {
    .footer-top {
      flex-direction: column;
    }
    .contact, .social-links {
      text-align: left;
      justify-content: flex-start;
    }
    .footer-bottom {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
    }
  }
</style>
