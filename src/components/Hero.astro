<section class="hero">
  <div class="hero-container">
    <div class="hero-content">

      <h1 class="title animate-fade-up delay-100">
        Get More Leads with a <span class="highlight">High-Converting</span> Website.
      </h1>
      <p class="description animate-fade-up delay-200">
        We help ambitious service businesses worldwide dominate local search and turn casual visitors into booked clients with blazing-fast, custom-coded websites.
      </p>
      <div class="actions animate-fade-up delay-300">
        <a href="#about" class="btn btn-primary">Discover More</a>
        <a href="https://wa.me/61412345678" class="btn btn-secondary">Let's Talk</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
    background-image: url('/hero_bg.png');
    background-size: cover;
    background-position: center;
    padding-top: 100px; /* Offset for fixed header */
  }

  /* Decorative background element */
  .hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(255, 255, 255, 0.8); /* 80% opacity as requested */
    z-index: 1;
  }

  .hero-container {
    position: relative;
    z-index: 2; /* Text above overlay */
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .hero-content {
    max-width: 800px;
  }



  .title {
    font-size: clamp(2.25rem, 5vw, 4.5rem);
    margin-bottom: 2.5rem; /* Ditambah dari 2rem */
    color: var(--color-primary);
    line-height: 1.1;
  }

  .highlight {
    color: var(--color-accent);
    font-style: italic;
  }

  .description {
    font-size: 1.35rem; /* Sedikit dibesarkan */
    color: var(--color-text-muted);
    margin-bottom: 4rem; /* Ditambah dari 3rem */
    max-width: 600px;
    line-height: 1.8; /* Lebih lega */
  }

  .actions {
    display: flex;
    gap: 1.5rem; /* Ditambah dari 1rem */
    margin-bottom: 4rem; /* Ditambah dari 2rem */
  }


  .btn {
    padding: 1rem 2rem;
    border-radius: 50px;
    font-weight: 500;
    font-size: 1.1rem;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .btn-primary {
    background-color: var(--color-primary);
    color: var(--color-cream);
    border: 2px solid var(--color-primary);
  }

  .btn-primary:hover {
    background-color: var(--color-accent);
    border-color: var(--color-accent);
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(15, 23, 42, 0.1);
  }

  .btn-secondary {
    background-color: transparent;
    color: var(--color-primary);
    border: 2px solid var(--color-primary);
  }

  .btn-secondary:hover {
    background-color: var(--color-primary);
    color: var(--color-cream);
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {

    .actions {
      flex-direction: column;
      gap: 1.25rem;
    }
    .btn {
      width: 100%;
      text-align: center;
    }
  }
</style>
