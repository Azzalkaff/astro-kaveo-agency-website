---
---

<section id="how-it-works" class="how-it-works">
  <div class="hiw-container">
    <div class="header-content animate-fade-up">
      <p class="subtitle">The Process</p>
      <h2 class="section-title">How It Works</h2>
      <p class="section-desc">A simple, zero-stress process. You focus on your trade, I handle the rest.</p>
    </div>

    <div class="timeline-container animate-fade-up delay-100">
      
      <!-- Step 1 -->
      <div class="timeline-step">
        <div class="step-marker">
          <span class="step-num">1</span>
        </div>
        <div class="step-content">
          <h3>Quick Chat</h3>
          <p>15-min call to discuss goals. No sales pressure.</p>
        </div>
      </div>

      <!-- Connector -->
      <div class="timeline-connector"></div>

      <!-- Step 2 -->
      <div class="timeline-step">
        <div class="step-marker highlight">
          <span class="step-num">2</span>
        </div>
        <div class="step-content">
          <h3>I Build It</h3>
          <p>Your premium lead-gen asset is built in 7 days.</p>
        </div>
      </div>

      <!-- Connector -->
      <div class="timeline-connector"></div>

      <!-- Step 3 -->
      <div class="timeline-step">
        <div class="step-marker">
          <span class="step-num">3</span>
        </div>
        <div class="step-content">
          <h3>You Profit</h3>
          <p>Love it? Pay the invoice and watch the leads roll in.</p>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .how-it-works {
    padding: 8rem 0;
    background-color: var(--color-primary);
    color: var(--color-cream);
  }

  .hiw-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .header-content {
    text-align: center;
    margin-bottom: 5rem;
  }

  .subtitle {
    font-size: 1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .section-title {
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    color: var(--color-cream);
    margin-bottom: 1rem;
  }

  .section-desc {
    font-size: 1.15rem;
    color: rgba(249, 246, 240, 0.7);
  }

  /* Horizontal Timeline */
  .timeline-container {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    position: relative;
    max-width: 900px;
    margin: 0 auto;
  }

  .timeline-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    width: 250px;
    z-index: 2;
  }

  .step-marker {
    width: 110px;
    height: 110px;
    background-color: var(--color-primary);
    border: 3px solid rgba(249, 246, 240, 0.2);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 2rem;
    transition: all 0.3s ease;
    box-shadow: 0 0 0 8px var(--color-primary);
  }

  .step-marker.highlight {
    background-color: var(--color-accent);
    border-color: var(--color-accent);
    transform: scale(1.1);
    box-shadow: 0 0 0 8px var(--color-primary), 0 0 30px rgba(59, 130, 246, 0.4);
  }

  .step-num {
    font-size: 4rem;
    font-weight: 800;
    color: var(--color-cream);
    font-family: var(--font-heading);
  }

  .timeline-step:hover .step-marker {
    border-color: var(--color-accent);
    transform: scale(1.1);
  }

  .step-content h3 {
    font-size: 1.6rem;
    color: var(--color-cream);
    margin-bottom: 1rem;
  }

  .step-content p {
    color: rgba(249, 246, 240, 0.7);
    font-size: 1.05rem;
    line-height: 1.6;
  }

  .timeline-connector {
    flex-grow: 1;
    height: 3px;
    background: rgba(249, 246, 240, 0.1);
    margin-top: 55px; /* Half of marker height */
    z-index: 1;
  }

  @media (max-width: 768px) {
    .timeline-container {
      flex-direction: column;
      align-items: center;
    }

    .timeline-connector {
      width: 3px;
      height: 60px;
      margin: 1rem 0;
    }

    .timeline-step {
      width: 100%;
      max-width: 300px;
    }
  }
</style>
