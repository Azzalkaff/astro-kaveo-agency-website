<section class="kpi">
  <div class="kpi-container">
    <div class="kpi-grid">
      
      <div class="kpi-item animate-fade-up">
        <div class="kpi-number">0</div>
        <div class="kpi-label">Lock-in Contracts</div>
        <div class="kpi-desc">We earn your business every single month through real results.</div>
      </div>

      <div class="kpi-item animate-fade-up delay-100">
        <div class="kpi-number">3</div>
        <div class="kpi-label">Target Cities</div>
        <div class="kpi-desc">Focused exclusively on local trades in Brisbane, Perth, and Adelaide.</div>
      </div>

      <div class="kpi-item animate-fade-up delay-200">
        <div class="kpi-number">2h</div>
        <div class="kpi-label">Max Response Time</div>
        <div class="kpi-desc">Seamless communication with minimal timezone differences.</div>
      </div>

      <div class="kpi-item animate-fade-up delay-300">
        <div class="kpi-number">100%</div>
        <div class="kpi-label">Dedicated Focus</div>
        <div class="kpi-desc">You work directly with the founder, never passed to a junior.</div>
      </div>

    </div>
  </div>
</section>

<style>
  .kpi {
    background-color: var(--color-dark-blue);
    color: var(--color-cream);
    padding: 5rem 0;
    border-top: 1px solid rgba(249, 246, 240, 0.1);
    border-bottom: 1px solid rgba(249, 246, 240, 0.1);
  }

  .kpi-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .kpi-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    text-align: center;
  }

  .kpi-item {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .kpi-number {
    font-family: var(--font-heading);
    font-size: 3.5rem;
    font-weight: 800;
    line-height: 1;
    margin-bottom: 0.5rem;
    color: var(--color-cream);
  }

  .kpi-label {
    font-size: 1.1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 1rem;
    color: rgba(249, 246, 240, 0.9);
  }

  .kpi-desc {
    font-size: 0.9rem;
    line-height: 1.6;
    color: rgba(249, 246, 240, 0.7);
    max-width: 250px;
  }

  @media (max-width: 1024px) {
    .kpi-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 3rem 2rem;
    }
  }

  @media (max-width: 640px) {
    .kpi-grid {
      grid-template-columns: 1fr;
    }
    .kpi-item {
      padding: 1rem 0;
    }
  }
</style>
