---
import '../styles/global.css';
import Hero from '../components/Hero.astro';
import KPI from '../components/KPI.astro';
import Niches from '../components/Niches.astro';
import About from '../components/About.astro';
import Services from '../components/Services.astro';
import Portfolio from '../components/Portfolio.astro';
import BeforeAfter from '../components/BeforeAfter.astro';
import ConversionZone from '../components/ConversionZone.astro';
import Pricing from '../components/Pricing.astro';
import HowItWorks from '../components/HowItWorks.astro';
import FAQ from '../components/FAQ.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Kaveo | High-Performance Web Design & Local SEO</title>
		<meta name="description" content="Kaveo builds high-converting, blazing-fast websites designed to generate leads and dominate local search for ambitious service businesses." />
	</head>
	<body>
		<Header />
		<main>
			<Hero />
			<KPI />
			<Niches />
			<Services />
			<Portfolio />
			<BeforeAfter />
			<ConversionZone />
			<Pricing />
			<HowItWorks />
			<About />
			<FAQ />
			<CTA />
		</main>
		<Footer />
	</body>
</html>
